# === 伺服器 ===
SERVER_PORT=8080
GIN_MODE=debug

# === JWT (必須跟 Django settings.py 的 SECRET_KEY 一字不差,token 才能互通) ===
JWT_SECRET=django-insecure-n$%*)n(3w2+hqlqbzij7yxvrp6c9&$wwib0kca(lk7!o^pqp%x
# 與 simplejwt 的 ACCESS_TOKEN_LIFETIME / REFRESH_TOKEN_LIFETIME 對齊
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# === PostgreSQL (連 Django 同一個 DB) ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123
DB_NAME=Django-DB1
DB_SSLMODE=disable

# CORS 允許來源 (逗號分隔)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
